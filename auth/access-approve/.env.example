# --- Keycloak / OIDC ---
OIDC_CLIENT_SECRET=ВСТАВИТЬ_СЕКРЕТ_КЛИЕНТА_access-approve
# Кто имеет право одобрять (через запятую, по username в Keycloak):
ADMIN_USERS=admin

# --- Криптоключи (сгенерировать длинные случайные строки) ---
SIGN_KEY=СГЕНЕРИРОВАТЬ_СЛУЧАЙНУЮ_СТРОКУ_64+
FLASK_SECRET=СГЕНЕРИРОВАТЬ_СЛУЧАЙНУЮ_СТРОКУ_64+

# --- Куда слать уведомления о заявках ---
NOTIFY_TO=admin@example.com

# --- SMTP для писем-уведомлений (заполнить под провайдера твоего No Reply) ---
# Пример Gmail:  SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_MODE=starttls
# Пример Yahoo:  SMTP_HOST=smtp.mail.yahoo.com  SMTP_PORT=465  SMTP_MODE=ssl
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_MODE=starttls

# --- Прочее (менять не обязательно) ---
# OIDC_ISSUER=https://auth.example.com/realms/homelab
# KC_INTERNAL=http://keycloak:8080
# BASE_URL=https://example.com/_access-approve
# ROLE_NAME=media
# REQUIRE_EMAIL_VERIFIED=true
# POLL_INTERVAL_SECONDS=120
