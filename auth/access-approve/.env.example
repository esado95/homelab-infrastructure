# --- Keycloak / OIDC ---
OIDC_CLIENT_SECRET=COLLER_LE_SECRET_DU_CLIENT_access-approve
# Qui a le droit d'approuver (séparés par des virgules, par username Keycloak) :
ADMIN_USERS=admin

# --- Clés cryptographiques (générer de longues chaînes aléatoires) ---
SIGN_KEY=GENERER_UNE_CHAINE_ALEATOIRE_64+
FLASK_SECRET=GENERER_UNE_CHAINE_ALEATOIRE_64+

# --- Où envoyer les notifications de demandes ---
NOTIFY_TO=admin@example.com

# --- SMTP pour les e-mails de notification (à remplir selon ton fournisseur No Reply) ---
# Exemple Gmail :  SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_MODE=starttls
# Exemple Yahoo :  SMTP_HOST=smtp.mail.yahoo.com  SMTP_PORT=465  SMTP_MODE=ssl
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_MODE=starttls

# --- Divers (modification facultative) ---
# OIDC_ISSUER=https://auth.example.com/realms/homelab
# KC_INTERNAL=http://keycloak:8080
# BASE_URL=https://example.com/_access-approve
# ROLE_NAME=media
# REQUIRE_EMAIL_VERIFIED=true
# POLL_INTERVAL_SECONDS=120
