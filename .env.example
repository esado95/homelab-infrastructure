# Exemple de variables d'environnement.
# Copier ce fichier en `.env` dans le dossier concerné et remplir avec TES valeurs.
# ⚠️ Ne JAMAIS committer les vrais fichiers .env — ils sont ignorés (voir .gitignore).

# --- Keycloak (auth/keycloak) ---
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=<mot_de_passe_admin_keycloak>
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=<mot_de_passe_base_de_donnees>
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=<mot_de_passe_postgres>
KEYCLOAK_HOSTNAME=auth.example.com

# --- Grafana (monitoring) ---
GF_SECURITY_ADMIN_PASSWORD=<mot_de_passe_grafana>

# --- access-approve : voir auth/access-approve/.env.example ---
