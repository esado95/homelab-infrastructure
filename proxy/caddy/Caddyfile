{
    email admin@example.com
}

# Domaine Jellyfin, accessible depuis Internet
example.com {

    encode gzip zstd

    # En-têtes de sécurité
    # X-Frame-Options RETIRÉ : l'app Jellyfin sur TV (webOS) charge le client dans une iframe,
    # et SAMEORIGIN bloquait cela (erreur -27). On le retire aussi des réponses de l'upstream.
    header {
        -X-Frame-Options
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # On désactive la mise en cache de l'interface Jellyfin
    @jellyfinIndex path /web/index.html /web/
    header @jellyfinIndex Cache-Control "no-store, no-cache, must-revalidate, max-age=0"

    @jellyfinSw path /web/serviceworker.js /web/service-worker.js /web/sw.js
    header @jellyfinSw Cache-Control "no-store, no-cache, must-revalidate, max-age=0"

    # CSS de branding sans cache -> les modifications du thème (tags Enhanced, couleurs) sont prises en compte immédiatement sur tous les clients
    @brandingCss path /Branding/Css
    header @brandingCss Cache-Control "no-store, no-cache, must-revalidate, max-age=0"

    # Déconnexion : page qui efface le token Jellyfin (localStorage + serveur),
    # puis déconnecte de Keycloak et redirige vers la page de connexion.
    @logout path /logout /logout/
    handle @logout {
        root * /srv/login-page
        rewrite * /logout.html
        header Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        file_server
    }

    # Écran de connexion pour la TV (QR + Quick Connect)
    handle /tv {
        root * /srv/login-page
        rewrite * /tv.html
        header Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        file_server
    }
    # Page de confirmation de connexion TV (ouverte sur le téléphone via le scan du QR)
    handle /tvlink {
        root * /srv/login-page
        rewrite * /tvlink.html
        header Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        file_server
    }

    # Page d'accueil Homelab -- UNIQUEMENT sur la racine du site "/".
    # Les visiteurs via navigateur voient le portail ; les applications natives Jellyfin
    # ne demandent jamais "/" (elles vont sur /web, /System, /Users, /socket, API...),
    # elles ne sont donc pas impactées.
    handle / {
        root * /srv/login-page
        file_server
    }

    # Homelab approve (login-gated), chemin caché
    @approve path /_access-approve /_access-approve/*
    handle @approve {
        reverse_proxy access-approve:8090
    }

    # Tout le reste -> Jellyfin (client web, plugin SSO, API, websocket)
    handle {
        reverse_proxy jellyfin:8096
    }
}

# Radarr, accessible uniquement depuis le réseau local et Tailscale
radarr.local {
    @allowed remote_ip 192.168.1.0/24 100.64.0.0/10
    handle @allowed {
        reverse_proxy radarr:7878
    }
    respond "Forbidden" 403
}

